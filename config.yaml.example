# Caelum-Agent configuration
# Copy this file to config.yaml, fill in your real values, and never commit it.

llm:
  # Kimi (Moonshot AI) API configuration
  provider: kimi
  base_url: https://api.moonshot.cn/v1
  api_key: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
  model: kimi-k2.6
  # Optional reasoning level for kimi-k2.6: minimal, low, medium, high.
  # Do NOT use "none"; the endpoint rejects it for this model.
  # reasoning_effort: minimal
  # Set to true to include Kimi's built-in Formula tools.
  enable_builtin_tools: true
  # Register the ReadDocument tool: uploads binary documents (PDF/DOCX/PPTX/
  # EPUB/XLSX) to the Kimi Files API for text extraction. The file content
  # leaves the machine (same trust level as screenshots sent to Kimi);
  # extracted text is cached locally by file hash. Set to false to keep
  # documents local-only.
  enable_file_extract: true
  # Register the ViewMedia tool: uploads local images (downscaled to 4K if
  # larger) and videos (re-encoded to 15fps/1080p via ffmpeg from PATH or the
  # bundled imageio-ffmpeg binary) so the model sees them natively. Source
  # files over 300 MB are rejected up front; a 100 MB upload cap applies after
  # compression; remote copies are swept when each task ends. Set to false to
  # keep media local-only.
  enable_media_upload: true
  # Which Formula tools to register. Comment out tools you do not want.
  # NOTE: Formula URIs use hyphens (e.g. code-runner, web-search); the registered
  #       tool name uses underscores (code_runner, web_search). The local
  #       RestrictedCodeRunner is the default code execution backend; the Formula
  #       code-runner can be enabled as an alternative.
  builtin_tools:
    - moonshot/web-search:latest
    - moonshot/fetch:latest
    - moonshot/quickjs:latest
    - moonshot/code-runner:latest
    - moonshot/convert:latest
    - moonshot/date:latest
    - moonshot/base64:latest
    - moonshot/excel:latest
    - moonshot/memory:latest
    - moonshot/rethink:latest
    - moonshot/random-choice:latest
    - moonshot/mew:latest

mcp_servers:
  # Browser automation. Requires Node.js and npx.
  playwright:
    command: npx
    args:
      - "-y"
      - "@playwright/mcp@latest"
    env: {}

  # Windows desktop automation. Requires the official windows-mcp package.
  # Install: uvx windows-mcp serve  OR  pip install windows-mcp
  windows:
    command: windows-mcp
    args:
      - "serve"
    env:
      PYTHONUNBUFFERED: "1"

  # Filesystem access. Provide one or more allowed directories.
  filesystem:
    command: npx
    args:
      - "-y"
      - "@modelcontextprotocol/server-filesystem@latest"
      - "E:/code/project/Caelum-Agent"
      - "C:/Users/%USERNAME%/Documents"
    env: {}

# GUI-Actor-3B local vision model
ui_detector:
  enabled: true
  # Lazy (default): load the model and run vision only when DesktopInteract
  # needs SoM coordinates. Pure compute/filesystem/API tasks never load the
  # model. Set to false to load at startup and run vision every perception.
  lazy: true
  # Warm-load the model at startup while keeping lazy inference. Only meaningful
  # when lazy: true. The model stays resident so the first DesktopInteract does
  # not stall on a multi-GB load, but perceive() still does NOT annotate every
  # frame (so non-UI rounds pay nothing). Defaults to true; set to false to defer
  # the multi-GB load to the first DesktopInteract (saves memory until then, but
  # the first SoM click stalls). Trade-off: ~7.6GB resident memory for a fast
  # first click. Has no effect when lazy: false (eager already preloads).
  preload: true
  # Auto SoM compensation (lazy mode only): when a perception finds an empty UI
  # tree but OCR text (a UIA-less app such as WeChat/Qt/Electron), run GUI-Actor
  # SoM detection automatically so the model gets clickable markers without
  # having to discover DesktopInteract. Costs one detection pass, and only on
  # UIA-less screens.
  auto_compensate: true
  model_path: ./models/gui-actor-3b
  device: cuda:0
  dtype: bfloat16
  # flash_attention_2 is faster but harder to install on Windows.
  # Use "sdpa" for broader compatibility.
  attn_implementation: sdpa
  topk: 3
  verifier:
    enabled: true
    # Verifier uses the same model; it re-runs inference to pick the best candidate.

screenshot:
  # Capture backend: mss (recommended) or PIL
  backend: mss
  # The model-facing screenshot uses the same inverse-DPI normalization as
  # OCR: the original image at 100% display scaling, 1/scale above that,
  # floored at a 1080p box. UpgradeVision switches to the full original.
  quality: 60
  format: JPEG
  # Whether to crop around the active window by default.
  crop_to_active_window: false

ocr:
  enabled: true
  backend: rapidocr_onnxruntime
  # GPU inference via DirectML (needs onnxruntime-directml; setup.py installs
  # it on Windows). Falls back to CPU automatically when DML is unavailable.
  use_dml: true

memory:
  # Local SQLite fallback for preferences, reflections, skills, audit log, state.
  sqlite_path: ./data/memory.db
  # Use Kimi's built-in memory Formula tool (moonshot/memory) when registered.
  # Falls back to SQLite if the tool is unavailable or disabled.
  use_kimi_memory: true

reflection:
  # Use Kimi's built-in rethink Formula tool (moonshot/rethink) for reflection.
  # Falls back to local SQLite records if the tool is unavailable or disabled.
  use_rethink: true

security:
  # Default action level for operations not otherwise classified.
  default_level: read
  # Levels: read, write_safe, write_risky, destructive
  auto_execute_levels:
    - read
    - write_safe
  confirm_levels:
    - write_risky
  destructive_requires_approval: true

logging:
  level: INFO
  format: "{time:YYYY-MM-DD HH:mm:ss} | {level} | {name} | {message}"
  data_dir: ./data

paths:
  skills_dir: ./skills
  cache_dir: ./data/cache
  audit_log: ./data/audit.log

# Kill switch / circuit breaker
kill_switch:
  enabled: true
  # Consecutive API failures before switching to local-only mode.
  api_failure_threshold: 5
  # Consecutive action failures before asking the user for guidance.
  action_failure_threshold: 3
  # Number of loops on the same UI before re-planning.
  same_ui_loop_threshold: 3
